//@ts-ignore

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ProfileTrack {
  DANCE
  MUSIC
  ART
}

enum ProfileExperience {
  NO_EXPERIENCE
  LESS_THAN_ONE_YEAR
  MORE_THAN_ONE_YEAR
}

enum ClassStatus {
  ACTIVE
  CANCELLED
  COMPLETED
  SUSPENDED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  CASH
}

enum InvoiceStatus {
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

enum NotificationType {
  INAPP
  EMAIL
  SMS
  BOTH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum SessionType {
  PUBLIC // Art, Dance, Ballet, Music Awakening — fixed monthly schedule
  TRIAL // One-time 10 OMR taster
  WORKSHOP // One-off event
  PRIVATE // Private classes (future)
}

enum BookingType {
  TRIAL
  MONTHLY_ONCE
  MONTHLY_TWICE
  WORKSHOP
  PRIVATE
}

enum FrequencyType {
  ONCE_PER_WEEK
  TWICE_PER_WEEK
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum GalleryMediaType {
  IMAGE
  VIDEO
}

enum GalleryVisibility {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_TRIAL
}

// ─────────────────────────────────────────────
// USER & PROFILES
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  role         Role      @default(STUDENT)
  isActive     Boolean   @default(true)
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  // NextAuth fields
  emailVerified DateTime?
  image         String?

  // Relations
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  adminProfile   AdminProfile?
  accounts       Account[]
  sessions       Session[]
  notifications  Notification[]
  supportTickets SupportTicket[]
  ticketReplies  TicketReply[]

  @@map("users")
}

model StudentProfile {
  id                      String             @id @default(cuid())
  userId                  String             @unique
  firstName               String
  lastName                String
  dateOfBirth             DateTime?
  gender                  Gender?
  address                 String?
  city                    String?
  country                 String?
  emergencyContact        String?
  emergencyContactName    String?
  emergencyContactPhone   String?
  emergencyRelationship   String?
  hasMedicalCondition     Boolean            @default(false)
  medicalConditionDetails String?
  agreePolicy             Boolean            @default(false)
  preferredTrack          ProfileTrack?
  experience              ProfileExperience?
  notes                   String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings              Booking[]
  monthlyEnrollments    MonthlyEnrollment[]
  trialBookings         TrialBooking[]
  workshopBookings      WorkshopBooking[]
  rescheduleLogs        RescheduleLog[]
  // ── NEW ──
  multiMonthEnrollments MultiMonthEnrollment[]

  @@map("student_profiles")
}

model TeacherProfile {
  id          String   @id @default(cuid())
  userId      String?  @unique
  firstName   String
  lastName    String
  bio         String?
  specialties String[]
  photoUrl    String?
  cvUrl       String?
  isAvailable Boolean  @default(true)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user                User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  teacherAvailability TeacherAvailability[]
  classSchedules      ClassSchedule[]
  subClassTeachers    SubClassTeacher[]
  workshops           Workshop[]

  @@map("teacher_profiles")
}

model AdminProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

// ─────────────────────────────────────────────
// NEXTAUTH TABLES
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// CLASSES & SUBCLASSES
// ─────────────────────────────────────────────

model Class {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconUrl     String?
  coverUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subClasses SubClass[]

  @@map("classes")
}

model SubClass {
  id                String      @id @default(cuid())
  classId           String
  name              String // e.g. "Violin", "Ballet for Kids", "Ballet"
  description       String?
  coverUrl          String?
  capacity          Int         @default(10)
  durationMinutes   Int         @default(60)
  price             Decimal     @db.Decimal(10, 2)
  currency          String      @default("OMR")
  level             String?
  ageGroup          String?
  isActive          Boolean     @default(true)
  sessionType       SessionType @default(PUBLIC)
  oncePriceMonthly  Decimal?    @db.Decimal(10, 2)
  twicePriceMonthly Decimal?    @db.Decimal(10, 2)
  trialPrice        Decimal     @default(10) @db.Decimal(10, 2)
  isTrialAvailable  Boolean     @default(true)
  // ── NEW ──
  // Controls whether students can reschedule individual sessions.
  // Set true for private/instrument classes (Piano, Oud, etc.)
  // Set false for group/public classes (Hip-Hop, Ballet, Art, etc.)
  isReschedulable   Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  class                 Class                  @relation(fields: [classId], references: [id])
  classSchedules        ClassSchedule[]
  trialBookings         TrialBooking[]
  teachers              SubClassTeacher[]
  monthlyEnrollments    MonthlyEnrollment[]
  // ── NEW ──
  multiMonthEnrollments MultiMonthEnrollment[]

  @@map("sub_classes")
}

// ─────────────────────────────────────────────
// SCHEDULING
// ─────────────────────────────────────────────

model TeacherAvailability {
  id        String    @id @default(cuid())
  teacherId String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_availabilities")
}

model ClassSchedule {
  id              String      @id @default(cuid())
  subClassId      String
  teacherId       String
  dayOfWeek       DayOfWeek
  startTime       String // "10:00"
  endTime         String // "11:00"
  startDate       DateTime
  endDate         DateTime?
  maxCapacity     Int
  currentEnrolled Int         @default(0)
  isRecurring     Boolean     @default(true)
  status          ClassStatus @default(ACTIVE)
  onlineLink      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  subClass SubClass       @relation(fields: [subClassId], references: [id])
  teacher  TeacherProfile @relation(fields: [teacherId], references: [id])
  sessions ClassSession[]

  @@map("class_schedules")
}

model ClassSession {
  id              String      @id @default(cuid())
  scheduleId      String
  sessionDate     DateTime
  // ── NEW ──
  // Combines sessionDate + startTime into one indexed DateTime for fast
  // 24-hour gate checks and free-slot queries. Set this whenever you
  // create or update a ClassSession. Example:
  //   sessionDatetime = new Date(`${sessionDate.toISOString().slice(0,10)}T${startTime}:00`)
  sessionDatetime DateTime
  startTime       String
  endTime         String
  status          ClassStatus @default(ACTIVE)
  cancelledReason String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  schedule            ClassSchedule   @relation(fields: [scheduleId], references: [id])
  bookings            Booking[]
  trialBookings       TrialBooking[]
  // ── NEW ──
  rescheduledFromLogs RescheduleLog[] @relation("OldSession")
  rescheduledToLogs   RescheduleLog[] @relation("NewSession")

  @@index([sessionDatetime])
  @@map("class_sessions")
}

// ─────────────────────────────────────────────
// BOOKINGS (regular single-session)
// ─────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  studentId       String
  sessionId       String
  status          BookingStatus @default(CONFIRMED)
  bookedAt        DateTime      @default(now())
  cancelledAt     DateTime?
  cancelledReason String?
  // rescheduledFrom kept as String? for a lightweight back-reference.
  // The full audit trail lives in RescheduleLog.
  rescheduledFrom String?
  canCancel       Boolean       @default(true)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  student             StudentProfile  @relation(fields: [studentId], references: [id])
  session             ClassSession    @relation(fields: [sessionId], references: [id])
  payment             Payment?
  notifications       Notification[]
  // ── NEW ──
  rescheduledFromLogs RescheduleLog[] @relation("OldBooking")
  rescheduledToLogs   RescheduleLog[] @relation("NewBooking")

  @@unique([studentId, sessionId])
  @@map("bookings")
}

// ─────────────────────────────────────────────
// RESCHEDULE LOG  ← NEW MODEL
// ─────────────────────────────────────────────

// One row per reschedule request. Covers both the success path
// (wasLost = false, newBookingId is set) and the "session lost"
// path (wasLost = true, newBookingId is null).
model RescheduleLog {
  id           String   @id @default(cuid())
  studentId    String
  oldBookingId String // the booking being replaced
  newBookingId String? // null when no free slot found
  oldSessionId String
  newSessionId String? // null when no free slot found
  requestedAt  DateTime @default(now())
  wasLost      Boolean  @default(false) // true = session lost, no slot available
  lostReason   String? // e.g. "No available sessions this month"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student    StudentProfile @relation(fields: [studentId], references: [id])
  oldBooking Booking        @relation("OldBooking", fields: [oldBookingId], references: [id])
  newBooking Booking?       @relation("NewBooking", fields: [newBookingId], references: [id])
  oldSession ClassSession   @relation("OldSession", fields: [oldSessionId], references: [id])
  newSession ClassSession?  @relation("NewSession", fields: [newSessionId], references: [id])

  @@index([studentId])
  @@index([oldBookingId])
  @@map("reschedule_logs")
}

// ─────────────────────────────────────────────
// MONTHLY ENROLLMENTS
// ─────────────────────────────────────────────

model MonthlyEnrollment {
  id                     String        @id @default(cuid())
  studentId              String
  subClassId             String
  month                  Int
  year                   Int
  frequency              FrequencyType
  preferredDays          DayOfWeek[]
  scheduleIds            String[]      @default([]) // exact ClassSchedule IDs enrolled
  status                 BookingStatus @default(CONFIRMED)
  totalAmount            Decimal       @db.Decimal(10, 2)
  currency               String        @default("OMR")
  bookedAt               DateTime      @default(now())
  // Null when booked month-by-month; set when part of a multi-month commitment.
  multiMonthEnrollmentId String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  student              StudentProfile        @relation(fields: [studentId], references: [id])
  subClass             SubClass              @relation(fields: [subClassId], references: [id])
  payment              MonthlyPayment?
  // ── NEW ──
  multiMonthEnrollment MultiMonthEnrollment? @relation(fields: [multiMonthEnrollmentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subClassId, month, year])
  @@map("monthly_enrollments")
}

model MonthlyPayment {
  id                    String         @id @default(cuid())
  enrollmentId          String         @unique
  amount                Decimal        @db.Decimal(10, 2)
  currency              String         @default("OMR")
  status                PaymentStatus  @default(PAID)
  method                PaymentMethod?
  stripePaymentIntentId String?        @unique
  paidAt                DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  enrollment MonthlyEnrollment @relation(fields: [enrollmentId], references: [id])

  @@map("monthly_payments")
}

// ─────────────────────────────────────────────
// MULTI-MONTH ENROLLMENT  ← NEW MODEL
// ─────────────────────────────────────────────

// Groups 2+ MonthlyEnrollment rows under a single parent booking
// so a student can commit (and pay) for several months at once.
// Example: student books Piano every Wednesday 10:00 for Jan + Feb + Mar.
// → One MultiMonthEnrollment (3 months, one payment)
// → Three MonthlyEnrollment rows, each with multiMonthEnrollmentId set
// → One MultiMonthPayment covering the full amount
model MultiMonthEnrollment {
  id            String        @id @default(cuid())
  studentId     String
  subClassId    String
  frequency     FrequencyType
  preferredDays DayOfWeek[]
  scheduleIds   String[]      @default([]) // exact ClassSchedule IDs enrolled
  // The calendar months covered, e.g. [{month:1,year:2026},{month:2,year:2026}]
  startMonth    Int
  startYear     Int
  endMonth      Int
  endYear       Int
  totalMonths   Int // convenience count, e.g. 3
  totalAmount   Decimal       @db.Decimal(10, 2)
  currency      String        @default("OMR")
  status        BookingStatus @default(CONFIRMED)
  bookedAt      DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  student            StudentProfile      @relation(fields: [studentId], references: [id])
  subClass           SubClass            @relation(fields: [subClassId], references: [id])
  monthlyEnrollments MonthlyEnrollment[] // the individual month rows
  payment            MultiMonthPayment?

  @@index([studentId])
  @@map("multi_month_enrollments")
}

// Single payment record for the entire multi-month commitment.
// MonthlyPayment is NOT used here — each month does not get its own payment.
model MultiMonthPayment {
  id                     String         @id @default(cuid())
  multiMonthEnrollmentId String         @unique
  amount                 Decimal        @db.Decimal(10, 2)
  currency               String         @default("OMR")
  status                 PaymentStatus  @default(PAID)
  method                 PaymentMethod?
  stripePaymentIntentId  String?        @unique
  paidAt                 DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  multiMonthEnrollment MultiMonthEnrollment @relation(fields: [multiMonthEnrollmentId], references: [id], onDelete: Cascade)

  @@map("multi_month_payments")
}

// ─────────────────────────────────────────────
// TRIAL BOOKINGS
// ─────────────────────────────────────────────

model TrialBooking {
  id         String        @id @default(cuid())
  studentId  String
  subClassId String
  sessionId  String
  status     BookingStatus @default(CONFIRMED)
  bookedAt   DateTime      @default(now())
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  student  StudentProfile @relation(fields: [studentId], references: [id])
  subClass SubClass       @relation(fields: [subClassId], references: [id])
  session  ClassSession   @relation(fields: [sessionId], references: [id])
  payment  Payment?

  @@unique([studentId, subClassId])
  @@map("trial_bookings")
}

// ─────────────────────────────────────────────
// WORKSHOPS
// ─────────────────────────────────────────────

model Workshop {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  imageUrls   String[] @default([])   
  videoUrls   String[] @default([])
  teacherId   String?
  roomId      String?
  eventDate   DateTime
  startTime   String
  endTime     String
  capacity    Int
  enrolledCount  Int      @default(0)
  reservedCount  Int      @default(0)
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("OMR")
  isActive    Boolean  @default(true)
  isOnline    Boolean  @default(false)
  onlineLink  String?
  slug  String?  @unique   // nullable first for backfill, then make required
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher  TeacherProfile?   @relation(fields: [teacherId], references: [id])
  room      Room?             @relation(fields: [roomId], references: [id])
  bookings WorkshopBooking[]

  @@map("workshops")
}

model WorkshopBooking {
  id         String        @id @default(cuid())
  workshopId String
  studentId  String
  status     BookingStatus @default(CONFIRMED)
  bookedAt   DateTime      @default(now())
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  workshop Workshop       @relation(fields: [workshopId], references: [id])
  student  StudentProfile @relation(fields: [studentId], references: [id])
  payment  Payment?

  @@unique([workshopId, studentId])
  @@map("workshop_bookings")
}

// ─────────────────────────────────────────────
// PAYMENTS & INVOICES
// ─────────────────────────────────────────────

model Payment {
  id                    String         @id @default(cuid())
  bookingId             String?        @unique
  trialBookingId        String?        @unique
  workshopBookingId     String?        @unique
  invoiceId             String?
  amount                Decimal        @db.Decimal(10, 2)
  currency              String         @default("OMR")
  status                PaymentStatus  @default(PAID)
  method                PaymentMethod?
  stripePaymentIntentId String?        @unique
  stripeSessionId       String?        @unique
  stripeChargeId        String?
  paidAt                DateTime?
  failedAt              DateTime?
  failureReason         String?
  refundedAmount        Decimal?       @db.Decimal(10, 2)
  refundedAt            DateTime?
  refundReason          String?
  metadata              Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  booking         Booking?         @relation(fields: [bookingId], references: [id])
  trialBooking    TrialBooking?    @relation(fields: [trialBookingId], references: [id])
  workshopBooking WorkshopBooking? @relation(fields: [workshopBookingId], references: [id])
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model Invoice {
  id          String        @id @default(cuid())
  invoiceNo   String        @unique
  studentId   String
  amount      Decimal       @db.Decimal(10, 2)
  tax         Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount Decimal       @db.Decimal(10, 2)
  currency    String        @default("OMR")
  status      InvoiceStatus @default(PAID)
  issuedAt    DateTime?
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payments Payment[]

  @@map("invoices")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

// IMPORTANT — Teacher notifications:
// TeacherProfile.userId is nullable. Before creating a Notification
// for a teacher, always check that teacherProfile.userId is not null.
// If null, fall back to notifying the admin instead.

model Notification {
  id           String             @id @default(cuid())
  userId       String
  imageUrl     String?
  linkUrl      String?
  readAt       DateTime?
  bookingId    String?
  type         NotificationType
  status       NotificationStatus @default(PENDING)
  subject      String?
  body         String
  sentAt       DateTime?
  failReason   String?
  scheduledFor DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@map("notifications")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// JOIN TABLES & SUPPORT
// ─────────────────────────────────────────────

model SubClassTeacher {
  teacherId  String
  subClassId String

  teacher  TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subClass SubClass       @relation(fields: [subClassId], references: [id], onDelete: Cascade)

  @@id([teacherId, subClassId])
  @@map("subclass_teachers")
}

model SupportTicket {
  id        String         @id @default(cuid())
  userId    String
  subject   String
  body      String
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(NORMAL)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@map("support_tickets")
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  body      String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ticket_replies")
}

// ─────────────────────────────────────────────
// GALLERY
// ─────────────────────────────────────────────

model GalleryCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items GalleryItem[]

  @@map("gallery_categories")
}

model GalleryItem {
  id                  String            @id @default(cuid())
  categoryId          String?
  mediaType           GalleryMediaType
  title               String?
  description         String?
  url                 String // Supabase Storage public URL
  thumbnailUrl        String? // video poster frame
  altText             String?
  visibility          GalleryVisibility @default(DRAFT)
  isFeatured          Boolean           @default(false)
  sortOrder           Int               @default(0)
  takenAt             DateTime?
  storageKey          String? // stable key for main file deletion
  thumbnailStorageKey String? // stable key for thumbnail deletion
  uploadedBy          String? // userId of uploader (soft ref, no FK)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  category GalleryCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  persons  GalleryItemPerson[]

  @@index([visibility, sortOrder])
  @@index([categoryId])
  @@map("gallery_items")
}

// Named people who can be tagged in gallery media.
// teacherId is a soft reference to TeacherProfile.id (no hard FK to avoid
// circular deps — just a lookup hint for the admin UI).
model GalleryPerson {
  id          String  @id @default(cuid())
  displayName String
  role        String? // "Teacher", "Student", "Guest Artist"
  photoUrl    String?
  teacherId   String? // soft ref to TeacherProfile.id

  items GalleryItemPerson[]

  @@map("gallery_persons")
}

model GalleryItemPerson {
  galleryItemId   String
  galleryPersonId String

  item   GalleryItem   @relation(fields: [galleryItemId], references: [id], onDelete: Cascade)
  person GalleryPerson @relation(fields: [galleryPersonId], references: [id], onDelete: Cascade)

  @@id([galleryItemId, galleryPersonId])
  @@map("gallery_item_persons")
}


// ─────────────────────────────────────────────
// UPCOMING
// ─────────────────────────────────────────────

model Upcoming {
  id           String        @id @default(cuid())
  title        String
  subtitle     String?
  description  String?       @db.Text
  mediaUrls    String[]      @default([])
  videoUrls    String[]      @default([])
  thumbnailUrl String?
  linkUrl      String?
  linkLabel    String?
  isExternal   Boolean       @default(false)
  eventDate    DateTime?
  publishAt    DateTime?
  expireAt     DateTime?
  status       ContentStatus @default(DRAFT)
  isActive     Boolean       @default(false)
  sortOrder    Int           @default(0)
  badgeLabel   String?
  createdBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workshopId  String?   @unique

  @@index([status, isActive, sortOrder])
  @@index([publishAt, expireAt])
  @@map("upcomings")
}

// ─────────────────────────────────────────────
// NEWS
// ─────────────────────────────────────────────

model News {
  id           String        @id @default(cuid())
  title        String
  subtitle     String?
  description  String?       @db.Text
  mediaUrls    String[]      @default([])
  videoUrls    String[]      @default([])
  thumbnailUrl String?
  linkUrl      String?
  linkLabel    String?
  isExternal   Boolean       @default(false)
  slug         String        @unique
  publishAt    DateTime?
  expireAt     DateTime?
  status       ContentStatus @default(DRAFT)
  isActive     Boolean       @default(false)
  sortOrder    Int           @default(0)
  badgeLabel   String?
  createdBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, isActive, sortOrder])
  @@index([publishAt, expireAt])
  @@map("news")
}

// ─────────────────────────────────────────────
// OFFERS
// ─────────────────────────────────────────────

model Offer {
  id             String        @id @default(cuid())
  title          String
  subtitle       String?
  description    String?       @db.Text
  mediaUrls      String[]      @default([])
  videoUrls      String[]      @default([])
  thumbnailUrl   String?
  linkUrl        String?
  linkLabel      String?
  isExternal     Boolean       @default(false)
  discountType   DiscountType?
  discountValue  Decimal?      @db.Decimal(10, 2)
  promoCode      String?       @unique
  classIds       String[]      @default([])   // ← add this
  subClassIds    String[]      @default([])
  publishAt      DateTime?
  expireAt       DateTime?
  status         ContentStatus @default(DRAFT)
  isActive       Boolean       @default(false)
  sortOrder      Int           @default(0)
  badgeLabel     String?
  createdBy      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, isActive, sortOrder])
  @@index([publishAt, expireAt])
  @@map("offers")
}


// ─────────────────────────────────────────────
// ROOM (new)
// ─────────────────────────────────────────────
model Room {
  id          String  @id @default(cuid())
  name        String  // e.g. "Studio A", "Main Hall"
  description String?
  capacity    Int     // max physical capacity of the room
  location    String? // floor, building, or address note
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workshops Workshop[]

  @@map("rooms")
}