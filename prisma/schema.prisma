// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ProfileTrack {
  DANCE
  MUSIC
  ART
}

enum ProfileExperience {
  NO_EXPERIENCE
  LESS_THAN_ONE_YEAR
  MORE_THAN_ONE_YEAR
}

enum ClassStatus {
  ACTIVE
  CANCELLED
  COMPLETED
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  CASH
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

enum NotificationType {
  EMAIL
  SMS
  BOTH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ── NEW ──────────────────────────────────────
enum SessionType {
  PUBLIC       // Art, Dance, Ballet, Music Awakening — fixed monthly schedule
  MUSIC        // Instrument lessons — teacher-driven schedule
  TRIAL        // One-time 10 OMR taster
  WORKSHOP     // One-off event
  PRIVATE      // Private classes (future)
}

enum BookingType {
  TRIAL
  MONTHLY_ONCE
  MONTHLY_TWICE
  WORKSHOP
  PRIVATE
}

enum FrequencyType {
  ONCE_PER_WEEK
  TWICE_PER_WEEK
}
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// USER & PROFILES
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  role         Role      @default(STUDENT)
  isActive     Boolean   @default(true)
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  // NextAuth fields
  emailVerified DateTime?
  image         String?

  // Relations
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  adminProfile   AdminProfile?
  accounts       Account[]
  sessions       Session[]
  notifications  Notification[]

  @@map("users")
}

model StudentProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  firstName        String
  lastName         String
  dateOfBirth      DateTime?
  gender           Gender?
  address          String?
  city             String?
  country          String?
  emergencyContact String?
  emergencyContactName String?
  emergencyContactPhone String?
  emergencyRelationship String?
  hasMedicalCondition   Boolean            @default(false)
  medicalConditionDetails String?
  agreePolicy           Boolean            @default(false)
  preferredTrack        ProfileTrack?
  experience            ProfileExperience?
  notes                 String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
  monthlyEnrollments MonthlyEnrollment[]
  trialBookings      TrialBooking[]
  workshopBookings   WorkshopBooking[]

  @@map("student_profiles")
}

model TeacherProfile {
  id          String   @id @default(cuid())
  userId      String?  @unique                    // ← String? (nullable)
  firstName   String
  lastName    String
  bio         String?
  specialties String[]
  photoUrl    String?
  cvUrl       String?
  isAvailable Boolean  @default(true)
  isActive    Boolean  @default(true)             // ← new field
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user                User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)  // ← SetNull not Cascade
  teacherAvailability TeacherAvailability[]
  classSchedules      ClassSchedule[]
  subClassTeachers SubClassTeacher[]
  workshops           Workshop[]

  @@map("teacher_profiles")
}

model AdminProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

// ─────────────────────────────────────────────
// NEXTAUTH TABLES
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// CLASSES & SUBCLASSES
// ─────────────────────────────────────────────

model Class {
  id          String   @id @default(cuid())
  name        String   // e.g. "Dance & Wellness", "Music", "Art", "Ballet", "Workshops"
  description String?
  iconUrl     String?
  coverUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subClasses SubClass[]

  @@map("classes")
}

model SubClass {
  id               String      @id @default(cuid())
  classId          String
  name             String      // e.g. "Piano", "Piano for Kids", "Ballet"
  description      String?
  coverUrl         String?
  capacity         Int         @default(10)
  durationMinutes  Int         @default(60)
  price            Decimal     @db.Decimal(10, 2)
  currency         String      @default("OMR")
  level            String?     // Beginner, Intermediate, Advanced
  ageGroup         String?     // Kids, Teens, Adults, All Ages
  isActive         Boolean     @default(true)
  // ── NEW fields ──
  sessionType      SessionType @default(PUBLIC)
  oncePriceMonthly  Decimal?   @db.Decimal(10, 2)  // price for once/week for a month
  twicePriceMonthly Decimal?   @db.Decimal(10, 2)  // price for twice/week for a month
  trialPrice        Decimal    @default(10)  @db.Decimal(10, 2)
  isTrialAvailable  Boolean    @default(true)
  // ────────────────
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  class          Class           @relation(fields: [classId], references: [id])
  classSchedules ClassSchedule[]
  trialBookings  TrialBooking[]
  teachers SubClassTeacher[]
  monthlyEnrollments MonthlyEnrollment[]

  @@map("sub_classes")
}

// ─────────────────────────────────────────────
// SCHEDULING
// ─────────────────────────────────────────────

model TeacherAvailability {
  id        String    @id @default(cuid())
  teacherId String
  dayOfWeek DayOfWeek
  startTime String // "09:00"
  endTime   String // "17:00"
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_availabilities")
}

model ClassSchedule {
  id              String      @id @default(cuid())
  subClassId      String
  teacherId       String
  dayOfWeek       DayOfWeek
  startTime       String      // "10:00"
  endTime         String      // "11:00"
  startDate       DateTime
  endDate         DateTime?
  maxCapacity     Int
  currentEnrolled Int         @default(0)
  isRecurring     Boolean     @default(true)
  isPublic        Boolean     @default(false)  // true = public fixed schedule
  status          ClassStatus @default(ACTIVE)
  onlineLink      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  subClass SubClass       @relation(fields: [subClassId], references: [id])
  teacher  TeacherProfile @relation(fields: [teacherId], references: [id])
  sessions ClassSession[]
  @@map("class_schedules")
}

model ClassSession {
  id              String      @id @default(cuid())
  scheduleId      String
  sessionDate     DateTime
  startTime       String
  endTime         String
  status          ClassStatus @default(ACTIVE)
  cancelledReason String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  schedule      ClassSchedule  @relation(fields: [scheduleId], references: [id])
  bookings      Booking[]
  trialBookings TrialBooking[]

  @@map("class_sessions")
}

// ─────────────────────────────────────────────
// BOOKINGS (regular single-session)
// ─────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  studentId       String
  sessionId       String
  status          BookingStatus @default(PENDING)
  bookedAt        DateTime      @default(now())
  cancelledAt     DateTime?
  cancelledReason String?
  rescheduledFrom String?
  canCancel       Boolean       @default(true)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  student       StudentProfile @relation(fields: [studentId], references: [id])
  session       ClassSession   @relation(fields: [sessionId], references: [id])
  payment       Payment?
  notifications Notification[]

  @@unique([studentId, sessionId])
  @@map("bookings")
}

// ─────────────────────────────────────────────
// MONTHLY ENROLLMENTS (public & music classes)
// ─────────────────────────────────────────────

model MonthlyEnrollment {
  id            String        @id @default(cuid())
  studentId     String
  subClassId    String
  month         Int           // 1–12
  year          Int
  frequency     FrequencyType
  preferredDays DayOfWeek[]
  status        BookingStatus @default(PENDING)
  totalAmount   Decimal       @db.Decimal(10, 2)
  currency      String        @default("OMR")
  bookedAt      DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  student  StudentProfile  @relation(fields: [studentId], references: [id])
  subClass SubClass        @relation(fields: [subClassId], references: [id])
  payment  MonthlyPayment?

  @@unique([studentId, subClassId, month, year])
  @@map("monthly_enrollments")
}

model MonthlyPayment {
  id                    String        @id @default(cuid())
  enrollmentId          String        @unique
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("OMR")
  status                PaymentStatus @default(PENDING)
  method                PaymentMethod?
  stripePaymentIntentId String?       @unique
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  enrollment MonthlyEnrollment @relation(fields: [enrollmentId], references: [id])

  @@map("monthly_payments")
}

// ─────────────────────────────────────────────
// TRIAL BOOKINGS
// ─────────────────────────────────────────────

model TrialBooking {
  id         String        @id @default(cuid())
  studentId  String
  subClassId String
  sessionId  String
  status     BookingStatus @default(PENDING)
  bookedAt   DateTime      @default(now())
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  student  StudentProfile @relation(fields: [studentId], references: [id])
  subClass SubClass       @relation(fields: [subClassId], references: [id])
  session  ClassSession   @relation(fields: [sessionId], references: [id])
  payment  Payment?

  @@unique([studentId, subClassId])
  @@map("trial_bookings")
}

// ─────────────────────────────────────────────
// WORKSHOPS
// ─────────────────────────────────────────────

model Workshop {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  teacherId   String?
  eventDate   DateTime
  startTime   String
  endTime     String
  capacity    Int
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("OMR")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher  TeacherProfile?   @relation(fields: [teacherId], references: [id])
  bookings WorkshopBooking[]

  @@map("workshops")
}

model WorkshopBooking {
  id         String        @id @default(cuid())
  workshopId String
  studentId  String
  status     BookingStatus @default(PENDING)
  bookedAt   DateTime      @default(now())
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  workshop Workshop       @relation(fields: [workshopId], references: [id])
  student  StudentProfile @relation(fields: [studentId], references: [id])
  payment  Payment?

  @@unique([workshopId, studentId])
  @@map("workshop_bookings")
}

// ─────────────────────────────────────────────
// PAYMENTS & INVOICES
// ─────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String?       @unique   // regular ClassSession booking
  trialBookingId        String?       @unique   // trial booking
  workshopBookingId     String?       @unique   // workshop booking (future)
  invoiceId             String?
  amount                Decimal        @db.Decimal(10, 2)
  currency              String         @default("OMR")
  status                PaymentStatus  @default(PENDING)
  method                PaymentMethod?
  stripePaymentIntentId String?        @unique
  stripeSessionId       String?        @unique
  stripeChargeId        String?
  paidAt                DateTime?
  failedAt              DateTime?
  failureReason         String?
  refundedAmount        Decimal?       @db.Decimal(10, 2)
  refundedAt            DateTime?
  refundReason          String?
  metadata              Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  booking         Booking?        @relation(fields: [bookingId], references: [id])
  trialBooking    TrialBooking?   @relation(fields: [trialBookingId], references: [id])
  workshopBooking WorkshopBooking? @relation(fields: [workshopBookingId], references: [id])
  invoice         Invoice?        @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model Invoice {
  id          String        @id @default(cuid())
  invoiceNo   String        @unique
  studentId   String
  amount      Decimal       @db.Decimal(10, 2)
  tax         Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount Decimal       @db.Decimal(10, 2)
  currency    String        @default("OMR")
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime?
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payments Payment[]

  @@map("invoices")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id           String             @id @default(cuid())
  userId       String
  bookingId    String?
  type         NotificationType
  status       NotificationStatus @default(PENDING)
  subject      String?
  body         String
  sentAt       DateTime?
  failReason   String?
  scheduledFor DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@map("notifications")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // e.g. "BOOKING_CREATED", "PAYMENT_FAILED"
  entity    String   // e.g. "Booking", "Payment"
  entityId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model SubClassTeacher {
  teacherId  String
  subClassId String
  teacher    TeacherProfile @relation(fields: [teacherId],  references: [id], onDelete: Cascade)
  subClass   SubClass       @relation(fields: [subClassId], references: [id], onDelete: Cascade)

  @@id([teacherId, subClassId])
  @@map("subclass_teachers")
}